# WhatsApp Bot 環境變數配置示例
# 請複製此文件為 .env 並填入實際值

# 管理員電話號碼 (多個用逗號分隔)
ADMIN_NUMBERS=1234567890@c.us,0987654321@c.us

# 授權群組ID (多個用逗號分隔)
AUTHORIZED_GROUPS=120363424519179359@g.us

# 應用配置
NODE_ENV=production
BOT_NAME=EngineeringBot

# 安全配置
WHITELIST_ENABLED=true
SECURITY_LOGGING=true

# 媒體配置
MEDIA_AUTO_DOWNLOAD=true
MEDIA_RETENTION_DAYS=30

# 日誌配置
LOG_LEVEL=info
LOG_FORMAT=json

# 清理配置
CLEANUP_ENABLED=true
CLEANUP_RETENTION_DAYS=30

# PM2 配置
PM2_INSTANCES=1
PM2_MEMORY_LIMIT=500M